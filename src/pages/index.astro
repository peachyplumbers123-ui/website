<!-- ============================================================
     HOW IT WORKS
     ============================================================ -->
<section id="about">
  <div class="shell">

    <div class="about-header section-header reveal">
      <p class="section-eyebrow">About Us</p>
      <h2 class="section-title">Expert plumbing and gas services<br>you can trust</h2>
    </div>

    <div class="about-body reveal" data-delay="300">
      <p>
        Based in Gravesend and serving Kent, I provide reliable, efficient and safe plumbing and gas
        engineering with 24/7 emergency support. Fully qualified and Gas Safe registered.
      </p>
      <p class="about-why">Why choose me</p>
      <p>
        Every job is approached with care, safety and professionalism. Whether it's a routine service or an
        urgent call-out, you'll get transparent pricing and work done right the first time. My focus is on
        quality workmanship and clear communication, turning stressful problems into straightforward fixes.
      </p>
    </div>

    <div class="steps-wrapper">
      <div class="steps-line" aria-hidden="true"></div>
      <div class="steps-grid reveal-group">

        <article class="step-card">
          <div class="step-num">1</div>
          <div class="step-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>Call</h3>
          <p>Tell us what is happening and we will book the best response window immediately.</p>
        </article>

        <article class="step-card">
          <div class="step-num">2</div>
          <div class="step-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>Diagnose</h3>
          <p>A qualified engineer assesses the issue and explains your options in plain language.</p>
        </article>

        <article class="step-card">
          <div class="step-num">3</div>
          <div class="step-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
